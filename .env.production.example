# =============================================================================
# Baby Planet BD — Production Environment Configuration
# -----------------------------------------------------------------------------
# Copy to .env.production and fill in real values BEFORE deploying.
# NEVER commit .env.production to git.
# =============================================================================

# ---- PostgreSQL ----
POSTGRES_USER=babyplanet_prod
POSTGRES_PASSWORD=CHANGE_ME_strong_password_min_32_chars
POSTGRES_DB=babyplanet_db_prod
DATABASE_URL="postgresql://babyplanet_prod:CHANGE_ME_strong_password_min_32_chars@postgres:5432/babyplanet_db_prod?schema=public"

# ---- Redis ----
REDIS_PASSWORD=CHANGE_ME_another_strong_password

# ---- JWT Secrets (use `openssl rand -hex 32` to generate) ----
JWT_ACCESS_SECRET=CHANGE_ME_use_openssl_rand_hex_32
JWT_REFRESH_SECRET=CHANGE_ME_use_openssl_rand_hex_32_diff
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
JWT_COOKIE_NAME=bp_token
JWT_REFRESH_COOKIE_NAME=bp_refresh_token

# ---- App URLs ----
CLIENT_URL=https://babyplanet-bd.com
ADMIN_URL=https://babyplanet-bd.com/admin
API_PREFIX=/api/v1
NODE_ENV=production

# ---- Backend port (internal only — NGINX proxies external traffic) ----
PORT=4000

# ---- Google OAuth 2.0 ----
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_CALLBACK_URL=https://api.babyplanet-bd.com/api/v1/auth/google/callback

# ---- Rate Limiting ----
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=300

# ---- Cache TTLs (seconds) ----
CACHE_TTL_PRODUCTS=300
CACHE_TTL_CATEGORIES=600
CACHE_TTL_PRODUCT_DETAIL=120

# ---- Frontend public env vars (NEXT_PUBLIC_ prefix required) ----
NEXT_PUBLIC_API_URL=https://api.babyplanet-bd.com
NEXT_PUBLIC_SITE_URL=https://babyplanet-bd.com
