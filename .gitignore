# =============================================================================
# Baby Planet BD Clone — .gitignore
# Covers: Next.js, Express backend, Prisma, Docker, NGINX, deploy artifacts
# =============================================================================

# ----- Dependencies -----
node_modules/
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions
backend/node_modules/

# ----- Next.js -----
/.next/
/out/
next-env.d.ts
*.tsbuildinfo

# ----- Build artifacts -----
/build
dist/
backend/dist/
*.tsbuildinfo

# ----- Environment files (NEVER commit real secrets) -----
.env
.env.local
.env.*.local
.env.production
.env.development
# Keep examples — they're safe to commit
!.env.example
!.env.production.example

# ----- Databases (local dev only) -----
db/*.db
db/*.db-journal
*.sqlite
*.sqlite3
backend/prisma/migrations/dev.db
backend/prisma/migrations/dev.db-journal

# ----- Logs -----
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
dev.log
dev.out.log
server.log
backend/logs/

# ----- Docker (local volumes + state) -----
nginx/cache/
nginx/logs/
docker-data/

# ----- OS / Editor -----
.DS_Store
Thumbs.db
.vscode/
.idea/
*.swp
*.swo
*~
.local-*

# ----- Testing -----
/coverage
*.lcov

# ----- Vercel -----
.vercel

# ----- Misc project-internal -----
.claude
.z-ai-config
/skills/
prompt
test
upload/

# ----- Prisma generated client (regenerated on install) -----
backend/node_modules/.prisma/

# ----- NGINX runtime -----
nginx_cache/
var/cache/nginx/

# ----- Let's Encrypt (local certbot testing) -----
certbot_certs/
certbot_webroot/
