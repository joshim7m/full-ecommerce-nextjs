# =============================================================================
# Baby Planet BD Backend — Environment Configuration Template
# Copy to `.env` and fill in real values before running `docker compose up`
# =============================================================================

# ---- Node / Express ----
NODE_ENV=development
PORT=4000
API_PREFIX=/api/v1
CLIENT_URL=http://localhost:3000
ADMIN_URL=http://localhost:3000/admin

# ---- PostgreSQL ----
POSTGRES_USER=babyplanet
POSTGRES_PASSWORD=babyplanet_secret
POSTGRES_DB=babyplanet_db
POSTGRES_PORT=5432
POSTGRES_HOST=localhost

# Connection string used by Prisma
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public
DATABASE_URL="postgresql://babyplanet:babyplanet_secret@localhost:5432/babyplanet_db?schema=public"

# ---- Redis ----
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=babyplanet_redis_secret
REDIS_DB=0

# ---- JWT ----
JWT_ACCESS_SECRET=replace_with_strong_random_string_min_32_chars
JWT_REFRESH_SECRET=replace_with_another_strong_random_string_min_32_chars
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
JWT_COOKIE_NAME=bp_token
JWT_REFRESH_COOKIE_NAME=bp_refresh_token

# ---- Google OAuth 2.0 ----
# Create credentials at https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here
GOOGLE_CALLBACK_URL=http://localhost:4000/api/v1/auth/google/callback

# ---- Rate Limiting ----
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=300

# ---- Cache TTL (seconds) ----
CACHE_TTL_PRODUCTS=300
CACHE_TTL_CATEGORIES=600
CACHE_TTL_PRODUCT_DETAIL=120

# ---- Misc ----
LOG_LEVEL=debug
