// =============================================================================
// Baby Planet BD Clone — Prisma Schema (PostgreSQL)
// =============================================================================
// Generator: prisma-client-js
// Datasource: PostgreSQL 16 (configured via DATABASE_URL env var)
// -----------------------------------------------------------------------------
// Indexing strategy:
//   - All primary keys use cuid() (globally unique, monotonic, no UUID overflow).
//   - Explicit @@index on every foreign-key column for JOIN performance.
//   - @@unique on natural keys (slug, email, phone) to enforce uniqueness AND
//     serve as a covering index for lookups.
//   - Compound @@index on (status, createdAt) for the admin order dashboard's
//     most common query: "show recent orders in status X".
// =============================================================================

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// =============================================================================
// ENUMS
// =============================================================================

enum UserRole {
  USER
  ADMIN
  MANAGER
}

enum UserStatus {
  ACTIVE
  SUSPENDED
  PENDING_VERIFICATION
}

enum ProductStatus {
  DRAFT
  ACTIVE
  OUT_OF_STOCK
  DISCONTINUED
}

enum ProductVisibility {
  PUBLISHED
  HIDDEN
}

enum OrderStatus {
  PENDING
  PROCESSING
  SHIPPED
  COMPLETED
  CANCELLED
}

enum PaymentStatus {
  UNPAID
  PENDING
  PAID
  REFUNDED
  FAILED
}

enum PaymentMethod {
  CASH_ON_DELIVERY
  BKASH
  NAGAD
  ROCKET
  CARD
}

enum ReviewStatus {
  PENDING
  APPROVED
  REJECTED
}

// =============================================================================
// USER — customers + admin/manager staff
// =============================================================================

model User {
  id              String           @id @default(cuid())
  email           String           @unique
  emailVerified   DateTime?
  password        String? // nullable because Google OAuth users have no password
  name            String?
  phone           String? @unique
  avatarUrl       String?
  role            UserRole         @default(USER)
  status          UserStatus       @default(ACTIVE)
  googleId        String? @unique
  refreshTokenHash String?
  lastLoginAt     DateTime?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  // Relations
  orders          Order[]
  reviews         Review[]
  cart            Cart?
  addresses       Address[]

  @@index([role])
  @@index([status])
  @@index([googleId])
  @@index([createdAt])
  @@map("users")
}

// =============================================================================
// CATEGORY — product taxonomy (Feeding, Mom Care, Kitchen, Clothing, Health…)
// =============================================================================

model Category {
  id          String    @id @default(cuid())
  slug        String    @unique
  name        String
  description String?
  imageUrl    String?
  iconUrl     String?
  parentId    String?   // self-reference for nested categories (optional)
  sortOrder   Int       @default(0)
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  // Relations
  parent      Category? @relation("CategoryHierarchy", fields: [parentId], references: [id], onDelete: SetNull)
  children    Category[] @relation("CategoryHierarchy")
  products    Product[]

  @@index([parentId])
  @@index([slug])
  @@index([isActive])
  @@index([sortOrder])
  @@map("categories")
}

// =============================================================================
// PRODUCT — sellable item
// =============================================================================

model Product {
  id              String            @id @default(cuid())
  slug            String            @unique
  name            String
  shortDescription String?
  description     String?
  // Price is stored as integer paisa (1 BDT = 100 paisa) to avoid float drift.
  // Display logic: BDT = pricePaisa / 100
  pricePaisa      BigInt
  compareAtPricePaisa BigInt? // original price for discount display
  costPricePaisa  BigInt?
  currency        String            @default("BDT")
  sku             String?           @unique
  barcode         String?
  stock           Int               @default(0)
  lowStockThreshold Int             @default(5)
  weightGrams     Int?
  status          ProductStatus     @default(DRAFT)
  visibility      ProductVisibility @default(PUBLISHED)
  isFeatured      Boolean           @default(false)
  isBestSeller    Boolean           @default(false)
  ratingAverage   Float             @default(0)
  ratingCount     Int               @default(0)
  salesCount      Int               @default(0)
  categoryId      String
  // Prisma JSON arrays — for images, tags, key features, dimensions, etc.
  images          Json              @default("[]")
  keyFeatures     Json              @default("[]")
  tags            Json              @default("[]")
  attributes      Json              @default("{}")
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  // Relations
  category        Category          @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  orderItems      OrderItem[]
  reviews         Review[]
  cartItems       CartItem[]
  wishlistItems   WishlistItem[]

  @@index([slug])
  @@index([categoryId])
  @@index([status])
  @@index([visibility])
  @@index([isFeatured])
  @@index([isBestSeller])
  @@index([sku])
  @@index([createdAt])
  @@index([salesCount])
  @@index([ratingAverage])
  @@map("products")
}

// =============================================================================
// ORDER — customer order header
// =============================================================================

model Order {
  id              String         @id @default(cuid())
  orderNumber     String         @unique // human-friendly e.g. BP-2025-000001
  userId          String?
  // Guest checkout support — store snapshot of customer info
  customerName    String
  customerPhone   String
  customerEmail   String?
  shippingAddress String
  note            String?
  status          OrderStatus    @default(PENDING)
  paymentStatus   PaymentStatus  @default(UNPAID)
  paymentMethod   PaymentMethod  @default(CASH_ON_DELIVERY)
  // Snapshot of totals in paisa
  subtotalPaisa   BigInt
  shippingCostPaisa BigInt       @default(0)
  discountPaisa   BigInt         @default(0)
  totalPaisa      BigInt
  trackingNumber  String?
  courierName     String?
  shippedAt       DateTime?
  deliveredAt     DateTime?
  cancelledAt     DateTime?
  // Audit
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  // Relations
  user            User?          @relation(fields: [userId], references: [id], onDelete: SetNull)
  items           OrderItem[]

  @@index([userId])
  @@index([status])
  @@index([paymentStatus])
  @@index([orderNumber])
  @@index([customerPhone])
  @@index([status, createdAt])
  @@index([createdAt])
  @@map("orders")
}

// =============================================================================
// ORDER_ITEM — line items in an order (snapshot of product at purchase time)
// =============================================================================

model OrderItem {
  id              String   @id @default(cuid())
  orderId         String
  productId       String
  productName     String   // denormalized snapshot
  productSlug     String   // denormalized snapshot
  productImage    String?  // denormalized snapshot
  unitPricePaisa  BigInt   // price at time of purchase
  quantity        Int
  lineTotalPaisa  BigInt
  createdAt       DateTime @default(now())

  // Relations
  order           Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product         Product  @relation(fields: [productId], references: [id], onDelete: Restrict)

  @@index([orderId])
  @@index([productId])
  @@index([productId, orderId])
  @@map("order_items")
}

// =============================================================================
// CART — per-user cart (anonymous carts use a session token stored in Redis)
// =============================================================================

model Cart {
  id        String     @id @default(cuid())
  userId    String     @unique
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  items     CartItem[]

  @@index([userId])
  @@map("carts")
}

model CartItem {
  id        String   @id @default(cuid())
  cartId    String
  productId String
  quantity  Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  cart      Cart     @relation(fields: [cartId], references: [id], onDelete: Cascade)
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([cartId, productId])
  @@index([cartId])
  @@index([productId])
  @@map("cart_items")
}

// =============================================================================
// WISHLIST — per-user product wishlist
// =============================================================================

model WishlistItem {
  id        String   @id @default(cuid())
  userId    String
  productId String
  createdAt DateTime @default(now())

  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([userId, productId])
  @@index([userId])
  @@index([productId])
  @@map("wishlist_items")
}

// =============================================================================
// REVIEW — product reviews (must be approved before public display)
// =============================================================================

model Review {
  id        String       @id @default(cuid())
  userId    String
  productId String
  orderId   String? // optional link to verified purchase
  rating    Int // 1..5
  title     String?
  body      String?
  images    Json         @default("[]")
  status    ReviewStatus @default(PENDING)
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  user      User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  product   Product      @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([userId, productId, orderId])
  @@index([productId])
  @@index([userId])
  @@index([status])
  @@index([rating])
  @@index([productId, status])
  @@map("reviews")
}

// =============================================================================
// ADDRESS — saved delivery addresses (optional, used in checkout flow)
// =============================================================================

model Address {
  id         String   @id @default(cuid())
  userId     String
  label      String?  // e.g. "Home", "Office"
  fullName   String
  phone      String
  addressLine String
  city       String
  thana      String?  // Bangladesh police station / upazila
  district   String
  postalCode String?
  isDefault  Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([district])
  @@map("addresses")
}

// =============================================================================
// COUPON — discount codes (optional, ready for future use)
// =============================================================================

model Coupon {
  id              String   @id @default(cuid())
  code            String   @unique
  description     String?
  // Percentage or fixed amount off
  discountType    String   @default("PERCENTAGE") // PERCENTAGE | FIXED
  discountValue   Int      @default(0) // percentage (1..100) or paisa
  minOrderPaisa   BigInt?
  maxDiscountPaisa BigInt?
  usageLimit      Int?
  usedCount       Int      @default(0)
  startsAt        DateTime?
  endsAt          DateTime?
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([code])
  @@index([isActive])
  @@index([startsAt, endsAt])
  @@map("coupons")
}
